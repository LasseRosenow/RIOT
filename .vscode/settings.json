{
    "editor.rulers": [
        80,
        120
    ],
    "editor.detectIndentation": false,
    "files.insertFinalNewline": true,
    "files.associations": {
        "Makefile.*": "makefile",
        "*.mk": "makefile",
        "intermediate-integration.h": "c",
        "plugtest-server.h": "c",
        "nanocoap_oscore_msg_conversion.h": "c",
        "protection.h": "c",
        "b1.h": "c",
        "primitive.h": "c",
        "persistence.h": "c",
        "demo-server.h": "c",
        "message.h": "c",
        "*.inc": "c"
    },
    "[shellscript][c][cpp]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
    },
    "[makefile]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
    },
}
